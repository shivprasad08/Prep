# -----------------------------
# PlacementGPT Environment File
# Copy this file to .env.local (development)
# and .env.production (production) and fill values.
# -----------------------------

# Groq API key for chat/model inference
GROQ_API_KEY=
# Groq model identifier
GROQ_MODEL=llama-3.3-70b-versatile

# Neon PostgreSQL connection string
DATABASE_URL=

# Clerk publishable key (safe for browser)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
# Clerk secret key (server only)
CLERK_SECRET_KEY=
# Clerk auth route settings
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard

# Cloudinary credentials for file uploads
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Pinecone vector index host and API key
PINECONE_API_KEY=
PINECONE_HOST=
PINECONE_GLOBAL_NAMESPACE=placementgpt_global

# Secret for /api/admin/ingest
ADMIN_SECRET_KEY=

# Sentry DSN for production error reporting
SENTRY_DSN=

# Public application URL used by client-side requests
NEXT_PUBLIC_APP_URL=

# Runtime mode
NODE_ENV=production
